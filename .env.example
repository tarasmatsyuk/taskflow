POSTGRES_USER=taskflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=taskflow
DATABASE_URL="postgresql://taskflow:change-me@localhost:5432/taskflow?schema=public"
REDIS_URL="redis://localhost:6379"

# Auth (M2) — generate strong values, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES=7d

# Google OAuth — OAuth 2.0 Web client ID from Google Cloud Console (Credentials).
# Used to verify Google Identity Services ID-tokens on POST /auth/google.
GOOGLE_CLIENT_ID=
# Same value as GOOGLE_CLIENT_ID above, exposed to the browser so the GIS
# "Continue with Google" button uses the matching client id. MUST be identical.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=