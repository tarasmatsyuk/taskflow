// TaskFlow — Prisma schema
// M1: User + Project. M2: auth fields on User. Tasks/members land in M3.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts (Migrate) and is passed
  // to PrismaClient via the pg driver adapter at runtime.
}

enum ProjectStatus {
  ACTIVE
  REVIEW
  ARCHIVED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(USER)
  // Nullable: pre-auth seed rows (and future OAuth users) have no local password.
  passwordHash       String?
  // Hashed (argon2) current refresh token; rotated on /auth/refresh, null on logout.
  hashedRefreshToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
}

model Project {
  id          String        @id @default(cuid())
  key         String        @unique
  name        String
  description String?
  color       String        @default("#c2f24f")
  status      ProjectStatus @default(ACTIVE)
  ownerId     String
  owner       User          @relation(fields: [ownerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ownerId])
}
