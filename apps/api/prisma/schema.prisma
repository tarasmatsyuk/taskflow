// TaskFlow — Prisma schema
// M1: User + Project. M2: auth fields on User. M3: Task + ProjectMember.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URL lives in prisma.config.ts (Migrate) and is passed
  // to PrismaClient via the pg driver adapter at runtime.
}

enum ProjectStatus {
  ACTIVE
  REVIEW
  ARCHIVED
}

enum UserRole {
  USER
  ADMIN
}

// Board columns (mockup: Backlog → To Do → In Progress → In Review → Done).
enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Per-project role on the membership join table.
enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(USER)
  // Nullable: pre-auth seed rows (and future OAuth users) have no local password.
  passwordHash       String?
  // Google account id (sub claim) for OAuth users; null for local-password users.
  // @unique: one Google account maps to one user (also indexes lookups by googleId).
  googleId           String? @unique
  // Hashed (argon2) current refresh token; rotated on /auth/refresh, null on logout.
  hashedRefreshToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects      Project[] // projects this user owns
  memberships   ProjectMember[] // projects this user belongs to
  assignedTasks Task[]          @relation("TaskAssignee")
  attachments   Attachment[]    @relation("UploadedAttachments") // files this user uploaded
}

model Project {
  id          String        @id @default(cuid())
  key         String        @unique
  name        String
  description String?
  color       String        @default("#c2f24f")
  status      ProjectStatus @default(ACTIVE)
  ownerId     String
  owner       User          @relation(fields: [ownerId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members ProjectMember[]
  tasks   Task[]
  labels  Label[]

  @@index([ownerId])
}

model Task {
  id          String       @id @default(cuid())
  number      Int // per-project sequence → renders as "TF-40"
  title       String
  description String?
  status      TaskStatus   @default(BACKLOG)
  priority    TaskPriority @default(MEDIUM)
  order       Float // position within its status column (fractional ordering)
  dueDate     DateTime?
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  deletedAt   DateTime? // soft delete (slice 5)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  labels      Label[]      @relation("TaskLabels")
  attachments Attachment[] // uploaded files (bytes in MinIO, metadata here)

  @@unique([projectId, number])
  // Covers the board query: WHERE projectId (+ status) ORDER BY status, order.
  @@index([projectId, status, order])
  @@index([assigneeId])
}

model ProjectMember {
  projectId String
  userId    String
  role      MemberRole @default(MEMBER)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@id([projectId, userId]) // composite PK = the M:N join
  @@index([userId])
}

model Label {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#56b6ff")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]   @relation("TaskLabels") // implicit M:N join (_TaskLabels)
  createdAt DateTime @default(now())

  @@unique([projectId, name])
  @@index([projectId])
}

// File attachment on a task. Bytes live in MinIO (S3-compatible); this row is
// the metadata for one uploaded object.
model Attachment {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  filename     String // original upload name, for display/download
  mimeType     String
  size         Int // bytes
  storageKey   String   @unique // object key/path in the MinIO bucket
  uploadedById String?
  // Null the uploader on user deletion rather than removing the attachment row.
  uploadedBy   User?    @relation("UploadedAttachments", fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([taskId])
}
