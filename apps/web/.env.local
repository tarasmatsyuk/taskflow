NEXT_PUBLIC_API_URL=http://localhost:4200/api

# Bare API origin for the realtime socket.io connection (NOT the /api prefix).
NEXT_PUBLIC_API_WS_URL=http://localhost:4200

# Server-side API base for the BFF route handlers
API_URL=http://localhost:4200/api

# Google OAuth Web client id for the "Continue with Google" GIS button.
# Must equal the API's GOOGLE_CLIENT_ID. Leave empty to hide the button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
